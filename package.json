{
  "name": "mcp-exec",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server for sandboxed code execution with context window reduction",
  "bin": {
    "mcp-exec": "./dist/src/server.js",
    "mcp-exec-install-skill": "./dist/bin/install-skill.js"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,json}": "biome check --write --unsafe --no-errors-on-unmatched"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.49",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^20.12.0",
    "@vitest/coverage-v8": "^1.6.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.12.0"
  }
}
